{
  "expo": {
    "name": "GymFlow Socios",
    "slug": "gym-saas-mobile",
    "scheme": "gymflowmember",
    "ios": {
      "bundleIdentifier": "com.gymflow.member",
      "associatedDomains": [
        "applinks:voltia-fitness.com"
      ]
    },
    "android": {
      "package": "com.gymflow.member",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "voltia-fitness.com",
              "pathPrefix": "/reset-password"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ]
  }
}
